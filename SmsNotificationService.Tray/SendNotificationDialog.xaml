<Window x:Class="SmsNotificationService.Tray.SendNotificationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Send Notification" Height="420" Width="380"
        WindowStartupLocation="CenterScreen" ShowInTaskbar="False"
        ResizeMode="NoResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Send Notification" FontSize="16" FontWeight="Bold" Margin="0,0,0,12"/>

        <StackPanel Grid.Row="1" Margin="0,0,0,8">
            <TextBlock Text="Phone Number *" FontWeight="SemiBold"/>
            <TextBox x:Name="PhoneBox" Margin="0,2,0,0"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,0,0,8">
            <TextBlock Text="M-Pesa Code *" FontWeight="SemiBold"/>
            <TextBox x:Name="MpesaCodeBox" Margin="0,2,0,0"/>
        </StackPanel>

        <StackPanel Grid.Row="3" Margin="0,0,0,8">
            <TextBlock Text="Receipt No" FontWeight="SemiBold"/>
            <TextBox x:Name="ReceiptNoBox" Margin="0,2,0,0"/>
        </StackPanel>

        <StackPanel Grid.Row="4" Margin="0,0,0,8">
            <TextBlock Text="Student Name" FontWeight="SemiBold"/>
            <TextBox x:Name="StudentNameBox" Margin="0,2,0,0"/>
        </StackPanel>

        <StackPanel Grid.Row="5" Margin="0,0,0,8">
            <TextBlock Text="Amount" FontWeight="SemiBold"/>
            <TextBox x:Name="AmountBox" Margin="0,2,0,0"/>
        </StackPanel>

        <StackPanel Grid.Row="6" Margin="0,0,0,8">
            <TextBlock Text="Admission No" FontWeight="SemiBold"/>
            <TextBox x:Name="AdmNoBox" Margin="0,2,0,0"/>
        </StackPanel>

        <TextBlock x:Name="MessageText" Grid.Row="7" VerticalAlignment="Center" FontWeight="SemiBold"/>

        <StackPanel Grid.Row="8" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Send" x:Name="SendButton" Click="SendButton_Click" Margin="0,0,8,0" Padding="16,6"/>
            <Button Content="Cancel" Click="CancelButton_Click" Padding="16,6"/>
        </StackPanel>
    </Grid>
</Window>
