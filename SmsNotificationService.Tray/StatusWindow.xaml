<Window x:Class="SmsNotificationService.Tray.StatusWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SmsNotificationService" Height="360" Width="380"
        WindowStartupLocation="CenterScreen" ShowInTaskbar="True"
        ResizeMode="NoResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="SmsNotificationService" FontSize="16" FontWeight="Bold" Margin="0,0,0,12"/>

        <StackPanel Grid.Row="1" Margin="0,0,0,4">
            <TextBlock FontWeight="SemiBold">Status</TextBlock>
            <TextBlock x:Name="StatusText" Margin="16,0,0,0"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,0,0,4">
            <TextBlock FontWeight="SemiBold">Uptime</TextBlock>
            <TextBlock x:Name="UptimeText" Margin="16,0,0,0"/>
        </StackPanel>

        <StackPanel Grid.Row="3" Margin="0,0,0,4">
            <TextBlock FontWeight="SemiBold">Version</TextBlock>
            <TextBlock x:Name="VersionText" Margin="16,0,0,0"/>
        </StackPanel>

        <StackPanel Grid.Row="4" Margin="0,0,0,4">
            <TextBlock FontWeight="SemiBold">Last Check</TextBlock>
            <TextBlock x:Name="LastCheckText" Margin="16,0,0,0"/>
        </StackPanel>

        <StackPanel Grid.Row="5" Margin="0,0,0,12">
            <TextBlock FontWeight="SemiBold">Detected via</TextBlock>
            <TextBlock x:Name="DetectionText" Margin="16,0,0,0" FontSize="11" Foreground="Gray"/>
        </StackPanel>

        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Start" x:Name="StartButton" Click="StartButton_Click" Margin="0,0,8,0" Padding="12,4"/>
            <Button Content="Stop" x:Name="StopButton" Click="StopButton_Click" Margin="0,0,8,0" Padding="12,4"/>
            <Button Content="Restart" x:Name="RestartButton" Click="RestartButton_Click" Padding="12,4"/>
        </StackPanel>
    </Grid>
</Window>
