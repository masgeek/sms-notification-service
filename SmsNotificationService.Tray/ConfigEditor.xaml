<Window x:Class="SmsNotificationService.Tray.ConfigEditor"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings — SmsNotificationService" Height="620" Width="500"
        WindowStartupLocation="CenterScreen" ShowInTaskbar="False"
        ResizeMode="NoResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Configuration" FontSize="16" FontWeight="Bold" Margin="0,0,0,12"/>

        <!-- Database -->
        <StackPanel Grid.Row="1" Margin="0,0,0,8">
            <TextBlock Text="Database" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Server:" VerticalAlignment="Center" Width="90"/>
                <TextBox Grid.Row="0" Grid.Column="1" x:Name="DbServerBox" Margin="0,2"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Database:" VerticalAlignment="Center" Width="90"/>
                <TextBox Grid.Row="1" Grid.Column="1" x:Name="DbNameBox" Margin="0,2"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="User ID:" VerticalAlignment="Center" Width="90"/>
                <TextBox Grid.Row="2" Grid.Column="1" x:Name="DbUserIdBox" Margin="0,2"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Password:" VerticalAlignment="Center" Width="90"/>
                <PasswordBox Grid.Row="3" Grid.Column="1" x:Name="DbPasswordBox" Margin="0,2"/>

                <TextBlock Grid.Row="4" Grid.Column="0" Text="Encrypt:" VerticalAlignment="Center" Width="90"/>
                <ComboBox Grid.Row="4" Grid.Column="1" x:Name="DbEncryptBox" Margin="0,2" Width="120" HorizontalAlignment="Left">
                    <ComboBoxItem Content="Mandatory" IsSelected="True"/>
                    <ComboBoxItem Content="Optional"/>
                    <ComboBoxItem Content="Strict"/>
                </ComboBox>
            </Grid>
        </StackPanel>

        <!-- SMS API -->
        <StackPanel Grid.Row="2" Margin="0,0,0,8">
            <TextBlock Text="SMS API" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="URL:" VerticalAlignment="Center" Width="90"/>
                <TextBox Grid.Column="1" x:Name="ApiUrlBox"/>
            </Grid>
            <Grid Margin="0,4,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Token:" VerticalAlignment="Center" Width="90"/>
                <PasswordBox Grid.Column="1" x:Name="TokenBox"/>
                <Button Grid.Column="2" x:Name="ToggleTokenButton" Content="Show" Click="ToggleTokenButton_Click" Margin="4,0,0,0" Padding="8,2"/>
            </Grid>
        </StackPanel>

        <!-- Retry Settings -->
        <StackPanel Grid.Row="3" Margin="0,0,0,8">
            <TextBlock Text="Retry Settings" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Backoff (s):" VerticalAlignment="Center"/>
                <TextBox Grid.Column="1" x:Name="BackoffBox" Margin="4,0,8,0"/>
                <TextBlock Grid.Column="2" Text="Poll Interval (s):" VerticalAlignment="Center"/>
                <TextBox Grid.Column="3" x:Name="PollIntervalBox" Margin="4,0,0,0"/>
            </Grid>
        </StackPanel>

        <!-- Logging -->
        <StackPanel Grid.Row="4" Margin="0,0,0,8">
            <TextBlock Text="Logging" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Retention Days:" VerticalAlignment="Center"/>
                <TextBox Grid.Column="1" x:Name="RetentionBox" Margin="4,0,8,0"/>
                <TextBlock Grid.Column="2" Text="Max Size (MB):" VerticalAlignment="Center"/>
                <TextBox Grid.Column="3" x:Name="MaxSizeBox" Margin="4,0,0,0"/>
            </Grid>
        </StackPanel>

        <TextBlock x:Name="ConfigPathText" Grid.Row="5" VerticalAlignment="Center"
                   FontSize="10" Foreground="Gray" TextWrapping="Wrap"/>

        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Test Connection" x:Name="TestButton" Click="TestButton_Click" Margin="0,0,8,0" Padding="12,4"/>
            <Button Content="Save" x:Name="SaveButton" Click="SaveButton_Click" Margin="0,0,8,0" Padding="12,4"/>
            <Button Content="Cancel" Click="CancelButton_Click" Padding="12,4"/>
        </StackPanel>
    </Grid>
</Window>
